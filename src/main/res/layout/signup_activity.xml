<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEAF7"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingTop="56dp"
        android:paddingBottom="48dp">

        <!-- 카드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:paddingLeft="28dp"
            android:paddingRight="28dp"
            android:paddingTop="32dp"
            android:paddingBottom="32dp">

            <!-- 상단 칩 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_chip"
                android:paddingLeft="10dp"
                android:paddingRight="14dp"
                android:layout_marginBottom="18dp">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_dot"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create your account"
                    android:textColor="#6667AB"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:letterSpacing="0.04"
                    android:fontFamily="@font/ChosunSg"/>
            </LinearLayout>

            <!-- 타이틀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="회원가입"
                android:textColor="#2C2C5B"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:layout_marginBottom="4dp"
                android:fontFamily="@font/ChosunSg"/>

            <!-- 서브타이틀 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="계정을 만들고 시작해보세요"
                android:textColor="#A49FC4"
                android:textSize="13sp"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/ChosunSg"/>

            <!-- 구분선 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0DCEF"
                android:layout_marginBottom="24dp"/>

            <!-- 이메일 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="E-MAIL"
                android:textColor="#6667AB"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/ChosunSg"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input"
                    android:layout_marginEnd="8dp">

                    <EditText
                        android:id="@+id/user_id"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="email@email.com"
                        android:textColorHint="#C0BCDC"
                        android:inputType="textEmailAddress"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:textColor="#2C2C5B"
                        android:textSize="14sp"
                        android:background="@null"
                        android:gravity="center_vertical"
                        android:fontFamily="@font/ChosunSg"/>
                </FrameLayout>

                <Button
                    android:layout_width="72dp"
                    android:layout_height="match_parent"
                    android:text="확인"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_primary"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:fontFamily="@font/ChosunSg"/>
            </LinearLayout>

            <!-- 사용자명 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사용자명"
                android:textColor="#6667AB"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/ChosunSg"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/user_name"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="앱 내에서 사용할 이름을 입력하세요"
                    android:textColorHint="#C0BCDC"
                    android:textColor="#2C2C5B"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:inputType="text"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:fontFamily="@font/ChosunSg"/>
            </FrameLayout>

            <!-- 비밀번호 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호"
                android:textColor="#6667AB"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/ChosunSg"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="6dp">

                <EditText
                    android:id="@+id/user_pw"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="비밀번호를 설정하세요"
                    android:textColorHint="#C0BCDC"
                    android:textColor="#2C2C5B"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:inputType="textPassword"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:fontFamily="@font/ChosunSg"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_pw_condition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:paddingLeft="4dp"
                android:layout_marginBottom="20dp"
                android:text=""
                android:fontFamily="@font/ChosunSg"/>

            <!-- 비밀번호 확인 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호 확인"
                android:textColor="#6667AB"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/ChosunSg"/>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="6dp">

                <EditText
                    android:id="@+id/user_pw_check"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="비밀번호를 다시 입력하세요"
                    android:textColorHint="#C0BCDC"
                    android:textColor="#2C2C5B"
                    android:textSize="14sp"
                    android:paddingLeft="16dp"
                    android:paddingRight="16dp"
                    android:inputType="textPassword"
                    android:background="@null"
                    android:gravity="center_vertical"
                    android:fontFamily="@font/ChosunSg"/>
            </FrameLayout>

            <TextView
                android:id="@+id/tv_pw_match_correct"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:paddingLeft="4dp"
                android:layout_marginBottom="8dp"
                android:text=""
                android:fontFamily="@font/ChosunSg"/>

        </LinearLayout>

        <!-- 개인정보 동의 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_checkbox_row"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="13dp"
            android:paddingBottom="13dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp">

            <CheckBox
                android:id="@+id/checkbox_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                android:buttonTint="#6667AB"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="개인정보 수집 및 이용에 동의합니다"
                android:textColor="#2C2C5B"
                android:textSize="13sp"
                android:fontFamily="@font/ChosunSg"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="보기 ›"
                android:textColor="#6667AB"
                android:textSize="12sp"
                android:textStyle="bold"
                android:fontFamily="@font/ChosunSg"/>
        </LinearLayout>

        <!-- 회원가입 버튼 -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="계정 만들기"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:background="@drawable/bg_button_primary"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/ChosunSg"/>

        <!-- 로그인 링크 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이미 계정이 있으신가요?"
                android:textColor="#B0ACCE"
                android:textSize="13sp"
                android:fontFamily="@font/ChosunSg"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  로그인"
                android:textColor="#6667AB"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="@font/ChosunSg"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>