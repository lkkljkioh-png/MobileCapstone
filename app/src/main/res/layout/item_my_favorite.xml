<?xml version="1.0" encoding="utf-8"?>
<!--
    MY 탭 - 즐겨찾기 자격증 목록 아이템
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/light_blue"
    app:strokeColor="@color/stroke_gray"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_fav_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_fav_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="12sp"
                android:textColor="@color/maintext_black" />

        </LinearLayout>

        <!-- 수정 하트로 교체 -->
        <TextView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:gravity="center"
            android:textSize="16sp"
            android:textColor="@color/deco_violet"
            android:text="♥"
            android:contentDescription="즐겨찾기" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
