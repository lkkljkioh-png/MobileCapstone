<?xml version="1.0" encoding="utf-8"?>

<!-- 자격증 세부 페이지 -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/detail_page_padding"
    android:background="@color/white">

    <!-- 상단 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tv_btn_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="〈"
            android:textSize="@dimen/back_btn_text_size"
            android:textColor="@color/accent_violet"
            android:fontFamily="@font/chosun_sg"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"/>

        <TextView
            android:id="@+id/tv_cert_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="자격증명"
            android:textColor="@color/accent_violet"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="@font/chosun_sg"
            android:includeFontPadding="true"
            android:lineSpacingExtra="4dp"
            android:minHeight="36dp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_btn_heart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="♡"
            android:textSize="28sp"
            android:textColor="@color/accent_violet"
            android:fontFamily="@font/chosun_sg"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <!-- 탭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/screen_padding">

        <TextView
            android:id="@+id/tv_tab_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="정보"
            android:textColor="@color/white"
            android:background="@color/accent_violet"
            android:padding="10dp"
            android:fontFamily="@font/chosun_sg" />

        <TextView
            android:id="@+id/tv_tab_question"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="기출문제"
            android:textColor="@color/accent_violet"
            android:layout_marginStart="@dimen/screen_padding"
            android:padding="10dp"
            android:fontFamily="@font/chosun_sg" />

        <TextView
            android:id="@+id/tv_tab_mock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="모의고사"
            android:textColor="@color/accent_violet"
            android:layout_marginStart="@dimen/screen_padding"
            android:padding="10dp"
            android:fontFamily="@font/chosun_sg" />
    </LinearLayout>

    <!-- 카드 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="#E6E6FA"
        app:cardCornerRadius="32dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="30dp">

                <!-- 제목 -->
                <TextView
                    android:id="@+id/tv_card_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="자격증명"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_violet"
                    android:fontFamily="@font/chosun_sg" />

                <!-- 설명 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📌 설명"
                    android:textStyle="bold"
                    android:textColor="@color/accent_violet"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/chosun_sg" />

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="설명 내용"
                    android:textColor="@color/text_body"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/chosun_sg" />

                <!-- 응시자격 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📌 응시 자격"
                    android:textStyle="bold"
                    android:textColor="@color/accent_violet"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/chosun_sg" />

                <TextView
                    android:id="@+id/tv_qualification"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="응시 자격 내용"
                    android:textColor="@color/text_body"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/chosun_sg" />

                <!-- 진로 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📌 도움 진로"
                    android:textStyle="bold"
                    android:textColor="@color/accent_violet"
                    android:layout_marginTop="20dp"
                    android:fontFamily="@font/chosun_sg" />

                <TextView
                    android:id="@+id/tv_job_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="진로 내용"
                    android:textColor="@color/text_body"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/chosun_sg" />

            </LinearLayout>
        </ScrollView>

    </androidx.cardview.widget.CardView>

</LinearLayout>
