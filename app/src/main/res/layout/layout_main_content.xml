<?xml version="1.0" encoding="utf-8"?>

<!-- 메인 홈 레이아웃 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#ECEAF7">

    <!-- 상단 헤더 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="22dp"
        android:paddingBottom="14dp">

        <View
            android:layout_width="36dp"
            android:layout_height="36dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="자격증 다모아"
            android:gravity="center"
            android:textColor="#2C2C5B"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="@font/chosun_sg"/>

        <!-- 메뉴 버튼 -->
        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_menu"
            android:background="@drawable/bg_chip"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

    <!-- 메인 스크롤 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="30dp">

            <!-- 메인 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="24dp">

                <!-- Home 칩 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_chip"
                    android:paddingLeft="10dp"
                    android:paddingRight="14dp"
                    android:paddingTop="5dp"
                    android:paddingBottom="5dp"
                    android:layout_marginBottom="18dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_dot"
                        android:layout_marginEnd="6dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Home"
                        android:textColor="#6667AB"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:fontFamily="@font/chosun_sg"/>
                </LinearLayout>

                <!-- 제목 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="오늘은 어떤 자격증을\n준비할까요?"
                    android:textColor="#2C2C5B"
                    android:textSize="25sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="5dp"
                    android:fontFamily="@font/chosun_sg"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="원하는 자격증 정보를 쉽게 찾아보세요"
                    android:textColor="#A49FC4"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="26dp"
                    android:fontFamily="@font/chosun_sg"/>

                <!-- 검색창 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input">

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:hint="자격증 검색하기"
                        android:textColorHint="#C0BCDC"
                        android:drawableStart="@android:drawable/ic_menu_search"
                        android:drawablePadding="10dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:textColor="#2C2C5B"
                        android:textSize="14sp"
                        android:background="@null"
                        android:gravity="center_vertical"
                        android:fontFamily="@font/chosun_sg"/>
                </FrameLayout>

                <!-- 칩 버튼 -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btn_favorite"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="즐겨찾기"
                            android:gravity="center"
                            android:textColor="#6667AB"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:background="@drawable/bg_chip"
                            android:paddingLeft="14dp"
                            android:paddingRight="14dp"
                            android:layout_marginEnd="8dp"
                            android:fontFamily="@font/chosun_sg"/>

                        <TextView
                            android:id="@+id/btn_all_cert"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="전체 자격증"
                            android:gravity="center"
                            android:textColor="#6667AB"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:background="@drawable/bg_chip"
                            android:paddingLeft="14dp"
                            android:paddingRight="14dp"
                            android:layout_marginEnd="8dp"
                            android:fontFamily="@font/chosun_sg"/>

                        <TextView
                            android:id="@+id/btn_calendar"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="캘린더"
                            android:gravity="center"
                            android:textColor="#6667AB"
                            android:textStyle="bold"
                            android:textSize="13sp"
                            android:background="@drawable/bg_chip"
                            android:paddingLeft="14dp"
                            android:paddingRight="14dp"
                            android:fontFamily="@font/chosun_sg"/>

                    </LinearLayout>
                </HorizontalScrollView>

            </LinearLayout>

            <!-- 카테고리 제목 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="카테고리"
                android:textColor="#2C2C5B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="14dp"
                android:fontFamily="@font/chosun_sg"/>

            <!-- 카테고리 1줄 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btnCategoryTech"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/baseline_phone_android"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IT · 기술"
                        android:textColor="#2C2C5B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/chosun_sg"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnCategoryIndustry"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/outline_build"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="산업"
                        android:textColor="#2C2C5B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/chosun_sg"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 카테고리 2줄 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/btnCategoryBusiness"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/outline_business_center"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="경영 · 사무"
                        android:textColor="#2C2C5B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/chosun_sg"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnCategoryPrimary"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/outline_eco"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="환경 · 자연"
                        android:textColor="#2C2C5B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/chosun_sg"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 카테고리 3줄 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/btnCategoryCreative"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/outline_brush"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="디자인"
                        android:textColor="#2C2C5B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/chosun_sg"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnCategoryService"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:background="@drawable/bg_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/round_accessibility"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="서비스"
                        android:textColor="#2C2C5B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginTop="10dp"
                        android:fontFamily="@font/chosun_sg"/>
                </LinearLayout>

            </LinearLayout>

            <!-- 최근 본 자격증 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최근 본 자격증"
                android:textColor="#2C2C5B"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/chosun_sg"/>

            <!-- 최근 본 카드 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recentRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:fontFamily="@font/chosun_sg" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>