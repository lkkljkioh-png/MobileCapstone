<?xml version="1.0" encoding="utf-8"?>

<!-- 메인 홈 레이아웃 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- 상단 홈 + 메뉴 아이콘 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <!-- 왼쪽 공백 (사이드탭 아이콘과 크기 맞춤) -->
        <View
            android:layout_width="36dp"
            android:layout_height="36dp" />

        <!-- 중앙 타이틀 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/app_title"
            android:textColor="@color/primary_blue"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- 오른쪽 사이드탭 아이콘 -->
        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_menu"
            android:contentDescription="@string/open_menu"
            android:clickable="true"
            android:focusable="true"
            android:padding="2dp" />
    </LinearLayout>

    <!-- 메인 콘텐츠 영역 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp">

            <!-- 검색창 -->
            <EditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="@string/search_hint"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:background="@drawable/bg_search"
                android:layout_marginTop="4dp"
                android:textColorHint="#94A3B8"
                android:textSize="14sp"
                android:elevation="2dp"
                android:inputType="text"
                android:singleLine="true" />

            <!-- 즐겨찾기 / 전체 자격증 칩 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:gravity="start">

                <TextView
                    android:id="@+id/btn_favorite"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/favorite_title"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="@color/maintext_black"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"/>

                <TextView
                    android:id="@+id/btn_all_cert"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/certificate_list_title"
                    android:gravity="center"
                    android:textSize="13sp"
                    android:textColor="@color/maintext_black"
                    android:background="@drawable/bg_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"/>
            </LinearLayout>

            <!-- 카테고리 타이틀 -->
            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_title"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/maintext_black"
                android:layout_marginTop="12dp"/>

            <!-- 카테고리 영역 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/category_container_margin_top">

                <!-- 1줄 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnCategoryTech"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/category_button_height"
                        android:layout_weight="1"
                        android:layout_margin="@dimen/category_small_margin"
                        android:background="@drawable/bg_category_gradient"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/category_tech"
                            android:textColor="@color/white"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_category_circle"
                            android:layout_gravity="center_vertical">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/baseline_phone_android"
                                android:scaleType="fitCenter" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnCategoryIndustry"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/category_button_height"
                        android:layout_weight="1"
                        android:layout_margin="@dimen/category_small_margin"
                        android:background="@drawable/bg_category_gradient"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/category_industry"
                            android:textColor="@color/white"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_category_circle"
                            android:layout_gravity="center_vertical">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/outline_build"
                                android:scaleType="fitCenter" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- 2줄 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnCategoryBusiness"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/category_button_height"
                        android:layout_weight="1"
                        android:layout_margin="@dimen/category_small_margin"
                        android:background="@drawable/bg_category_gradient"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/category_business"
                            android:textColor="@color/white"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_category_circle"
                            android:layout_gravity="center_vertical">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/outline_business_center"
                                android:scaleType="fitCenter" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnCategoryPrimary"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/category_button_height"
                        android:layout_weight="1"
                        android:layout_margin="@dimen/category_small_margin"
                        android:background="@drawable/bg_category_gradient"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/category_primary"
                            android:textColor="@color/white"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_category_circle"
                            android:layout_gravity="center_vertical">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/outline_eco"
                                android:scaleType="fitCenter" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- 3줄 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btnCategoryCreative"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/category_button_height"
                        android:layout_weight="1"
                        android:layout_margin="@dimen/category_small_margin"
                        android:background="@drawable/bg_category_gradient"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/category_creative"
                            android:textColor="@color/white"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_category_circle"
                            android:layout_gravity="center_vertical">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/outline_brush"
                                android:scaleType="fitCenter" />
                        </FrameLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnCategoryService"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/category_button_height"
                        android:layout_weight="1"
                        android:layout_margin="@dimen/category_small_margin"
                        android:background="@drawable/bg_category_gradient"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="10dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/category_service"
                            android:textColor="@color/white"
                            android:textStyle="bold"/>

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_category_circle"
                            android:layout_gravity="center_vertical">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:src="@drawable/round_accessibility"
                                android:scaleType="fitCenter" />
                        </FrameLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- 최근 본 자격증 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최근 본 자격증"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <!-- 아이템 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="10dp"
                android:background="@color/light_blue">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/cert_name_ex"
                    android:textSize="14sp"
                    android:textColor="#333333"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/category_name_ex"
                    android:textSize="12sp"
                    android:textColor="#888888"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_blue"/>

            <include layout="@layout/item_recent"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/light_blue"/>

            <include layout="@layout/item_recent"/>

        </LinearLayout>
    </ScrollView>

</LinearLayout>