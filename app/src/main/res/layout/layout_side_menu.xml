<?xml version="1.0" encoding="utf-8"?>

<!-- 사이드 메뉴 레이아웃 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/layout_side_menu"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_side_menu"
    android:elevation="12dp"
    android:paddingTop="24dp"
    android:paddingBottom="24dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp">

    <!-- 상단 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="메뉴"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/maintext_black" />

        <ImageView
            android:id="@+id/img_btn_close_menu"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:contentDescription="닫기" />
    </LinearLayout>

    <!-- 메뉴 1 -->
    <LinearLayout
        android:id="@+id/layout_menu_home"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_side_menu_item"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/maintext_black" />
    </LinearLayout>

    <!-- 메뉴 2 -->
    <LinearLayout
        android:id="@+id/layout_menu_list"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_side_menu_item"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/certificate_list_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/maintext_black" />
    </LinearLayout>

    <!-- 메뉴 3 -->
    <LinearLayout
        android:id="@+id/layout_menu_my"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_side_menu_item"
        android:clickable="true"
        android:focusable="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MY"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/maintext_black" />
    </LinearLayout>

</LinearLayout>
